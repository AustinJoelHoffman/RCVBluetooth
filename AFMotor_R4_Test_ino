void loop () {
  if (Serial.available()) {
      cmd = Serial.read();
      speed = cmd - '0';
  }

  if (speed == 0) {  // Speed 0
      motorL.setSpeed(0);
      motorR.setSpeed(0);
      Serial.println("Speed: Off");
  }                                  // TODO: 50 is to low to drive wheels
  else if (speed == 2) {  // Slow
    motorL.setSpeed(150);
    motorR.setSpeed(150);
    Serial.println("Speed: Slow");
  }
  else if (speed == 3) {  // Fast
    motorL.setSpeed(250);
    motorR.setSpeed(250);
    Serial.println("Speed: Fast");
  }
  else {}

  if (cmd == 'F') {  // Forward
    motorL.run(FORWARD);
    motorR.run(FORWARD);
    Serial.println(cmd);
    delay(500);
  }
  else if (cmd == 'B') {  // Backward
    motorL.run(BACKWARD);
    motorR.run(BACKWARD);
    Serial.println(cmd);
    delay(500);
  }
  else if (cmd == 'L') {  // Skid Left
    motorL.run(FORWARD);
    motorR.run(RELEASE);
    Serial.println(cmd);
    delay(500);
  }
  else if (cmd == 'R') {  // Skid Right
    motorL.run(RELEASE);
    motorR.run(FORWARD);
    Serial.println(cmd);
    delay(500);
  }
  else if (cmd == 'Q') {  // Spin Left
    motorL.run(FORWARD);
    motorR.run(BACKWARD);
    Serial.println(cmd);
    delay(500);
  }
  else if (cmd == 'E') {  // Spin Left
    motorL.run(FORWARD);
    motorR.run(BACKWARD);
    Serial.println(cmd);
    delay(500);
  }
  else if (cmd == 'P') {  // Release
    motorL.run(RELEASE);
    motorR.run(RELEASE);
    Serial.println(cmd);
    delay(500);
  }
  else if (cmd == 'S') {  // Stop
    motorL.run(BRAKE);
    motorR.run(BRAKE);
    Serial.println(cmd);
    delay(500);
  }
  else{}
  speed = 9;  // Reset speed input
}
